ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda-12.6/bin/nvcc

cflags = -pthread -B /home/hynx/miniconda3/envs/DCVC/compiler_compat -fno-strict-overflow -Wsign-compare -DNDEBUG -O2 -Wall -fPIC -O2 -isystem /home/hynx/miniconda3/envs/DCVC/include -fPIC -O2 -isystem /home/hynx/miniconda3/envs/DCVC/include -fPIC -I/home/hynx/miniconda3/envs/DCVC/lib/python3.12/site-packages/torch/include -I/home/hynx/miniconda3/envs/DCVC/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -I/usr/local/cuda-12.6/include -I/home/hynx/miniconda3/envs/DCVC/include/python3.12 -c
post_cflags = -O3 -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=inference_extensions_cuda -std=c++17
cuda_cflags = -I/home/hynx/miniconda3/envs/DCVC/lib/python3.12/site-packages/torch/include -I/home/hynx/miniconda3/envs/DCVC/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -I/usr/local/cuda-12.6/include -I/home/hynx/miniconda3/envs/DCVC/include/python3.12 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -O3 --use_fast_math --extra-device-vectorization -arch=native -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=inference_extensions_cuda -std=c++17
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags







